{
  "manifest_version": 3,
  "name": "reThink Outreach",
  "version": "1.2.0",
  "description": "Add LinkedIn contacts to reThink Outreach with one right-click",
  "permissions": ["contextMenus", "storage", "notifications", "tabs"],
  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://media.licdn.com/*",
    "https://amvezbymrnvrwcypivkf.supabase.co/*"
  ],
  "background": { "service_worker": "background.js" },
  "content_scripts": [{ "matches": ["https://www.linkedin.com/*"], "js": ["content.js"] }],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "96": "icon96.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "reThink Outreach",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  }
}
