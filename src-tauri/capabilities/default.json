{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main",
    "compact"
  ],
  "permissions": [
    "core:default",
    "updater:default",
    "process:allow-restart",
    "notification:default",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        { "url": "https://**" },
        { "url": "http://**" },
        { "url": "mailto:**" }
      ]
    }
  ]
}
