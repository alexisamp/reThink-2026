{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "reThink",
  "version": "0.1.84",
  "identifier": "com.rethink.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": " ",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "center": true
      },
      {
        "label": "compact",
        "title": "reThink",
        "width": 480,
        "height": 340,
        "minWidth": 480,
        "minHeight": 340,
        "maxWidth": 480,
        "maxHeight": 340,
        "alwaysOnTop": true,
        "decorations": false,
        "visible": false,
        "url": "/compact"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "signingIdentity": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEREOEE3RkIzRTVFRDhDOUYKUldTZmpPM2xzMytLM1NxTDgwNFJRSjAyZmJONEZ0Tm5xTXR2RzRrYlN4cmVJKzFaUW1xTzcxSlQK",
      "endpoints": [
        "https://github.com/alexisamp/reThink-2026/releases/latest/download/latest.json"
      ],
      "dialog": true
    }
  }
}
